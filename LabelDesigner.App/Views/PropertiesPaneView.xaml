<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LabelDesigner.App.Views.PropertiesPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:LabelDesigner.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
        <Style TargetType="TextBox" x:Key="PropBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderBrush" Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,0"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="6,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderText" Grid.Column="0" Text="Properties"
                        FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Foreground="#2B2B2B"/>
                    <ToggleButton Grid.Column="1" x:Name="CollapseToggle"
                        Width="28" Height="28" Padding="0" IsChecked="False"
                        Checked="OnCollapseToggleChanged" Unchecked="OnCollapseToggleChanged"
                        AutomationProperties.Name="Collapse Properties panel"
                        ToolTipService.ToolTip="Collapse Properties panel">
                        <FontIcon x:Name="CollapseIcon" Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </ToggleButton>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" x:Name="ContentArea" Padding="8,4"
                Visibility="{Binding Designer.Properties.IsVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding Designer.Properties.ElementType}" FontWeight="Bold" FontSize="15" Margin="0,4,0,4" Foreground="#2B2B2B"/>
                    <TextBlock Text="Name" FontSize="11" Foreground="#888"/>
                    <TextBox Text="{Binding Designer.Properties.ElementName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"/>
                    <TextBlock Text="Position" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Designer.Properties.PosX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}" PlaceholderText="X" Margin="0,0,2,0"/>
                        <TextBox Grid.Column="1" Text="{Binding Designer.Properties.PosY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}" PlaceholderText="Y" Margin="2,0,0,0"/>
                    </Grid>
                    <TextBlock Text="Size" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Designer.Properties.Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}" PlaceholderText="W" Margin="0,0,2,0"/>
                        <TextBox Grid.Column="1" Text="{Binding Designer.Properties.Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}" PlaceholderText="H" Margin="2,0,0,0"/>
                    </Grid>
                    <TextBlock Text="Rotation" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                    <TextBox Text="{Binding Designer.Properties.Rotation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"/>
                    <TextBlock Text="Font Size" FontSize="11" Foreground="#888" Margin="0,4,0,2"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding Designer.Properties.FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Font Family" FontSize="11" Foreground="#888" Margin="0,4,0,2"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding Designer.Properties.FontFamily, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,4,0,2"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}">
                        <ToggleButton Content="B" FontWeight="Bold" Width="28" Height="24" Padding="0" FontSize="13"
                            IsChecked="{Binding Designer.Properties.IsBold, Mode=TwoWay}" ToolTipService.ToolTip="Bold"/>
                        <ToggleButton Content="I" FontStyle="Italic" Width="28" Height="24" Padding="0" FontSize="13"
                            IsChecked="{Binding Designer.Properties.IsItalic, Mode=TwoWay}" ToolTipService.ToolTip="Italic"/>
                        <ToggleButton Content="U" Width="28" Height="24" Padding="0" FontSize="13"
                            IsChecked="{Binding Designer.Properties.IsUnderline, Mode=TwoWay}" ToolTipService.ToolTip="Underline"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,2,0,2"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}">
                        <RadioButton Content="L" GroupName="TxtAlign" Tag="0" FontSize="11" Padding="2,0"
                            IsChecked="{Binding Designer.Properties.TextAlignmentIndex, Converter={StaticResource BoolToVisibility}, ConverterParameter=0, Mode=OneWay}"
                            ToolTipService.ToolTip="Align Left"/>
                        <RadioButton Content="C" GroupName="TxtAlign" Tag="1" FontSize="11" Padding="2,0"
                            ToolTipService.ToolTip="Align Center"/>
                        <RadioButton Content="R" GroupName="TxtAlign" Tag="2" FontSize="11" Padding="2,0"
                            ToolTipService.ToolTip="Align Right"/>
                        <CheckBox Content="Multi" IsChecked="{Binding Designer.Properties.IsMultiline, Mode=TwoWay}" FontSize="10" ToolTipService.ToolTip="Multi-line text"/>
                    </StackPanel>
                    <TextBlock Text="Text Color" FontSize="11" Foreground="#888" Margin="0,4,0,2"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding Designer.Properties.ForeColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Text" FontSize="11" Foreground="#888" Margin="0,4,0,2"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding Designer.Properties.Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"
                        Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Barcode Value" FontSize="11" Foreground="#888" Margin="0,4,0,2"
                        Visibility="{Binding Designer.IsBarcodeSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBox Text="{Binding Designer.Properties.BarcodeValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}"
                        Visibility="{Binding Designer.IsBarcodeSelected, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="Fill Color" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" BorderThickness="1" BorderBrush="#D0D0D0" CornerRadius="3" Margin="0,0,4,0"
                            Background="{Binding Designer.Properties.FillColorValue, Converter={StaticResource ColorToBrush}}"/>
                        <TextBox Grid.Column="1" Text="{Binding Designer.Properties.FillColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}" PlaceholderText="#RRGGBB"/>
                    </Grid>
                    <TextBlock Text="Stroke Color" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="22" Height="22" BorderThickness="1" BorderBrush="#D0D0D0" CornerRadius="3" Margin="0,0,4,0"
                            Background="{Binding Designer.Properties.StrokeColorValue, Converter={StaticResource ColorToBrush}}"/>
                        <TextBox Grid.Column="1" Text="{Binding Designer.Properties.StrokeColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource PropBox}" PlaceholderText="#RRGGBB"/>
                    </Grid>
                    <TextBlock Text="Palette" FontSize="11" Foreground="#888" Margin="0,4,0,2"/>
                    <ItemsControl ItemsSource="{Binding Designer.Properties.PaletteColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VariableSizedWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="8" ItemWidth="22" ItemHeight="22"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="20" Height="20" Padding="0" Margin="1"
                                    Command="{Binding Designer.Properties.SelectColorCommand}"
                                    CommandParameter="{Binding}" BorderBrush="Transparent"
                                    Background="{Binding Converter={StaticResource ColorToBrush}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
