<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LabelDesigner.App.Views.DataMergePaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:LabelDesigner.App.Views"
    xmlns:conv="using:LabelDesigner.App.Converters"
    xmlns:sfgrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Background="{ThemeResource AppSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Top action bar ══ -->
        <Border Grid.Row="0"
                Background="{ThemeResource AppSurfaceAltBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                              Foreground="{ThemeResource AppGlyphBrush}"/>
                    <TextBlock Text="Data Merge" FontWeight="SemiBold" FontSize="13"
                               Foreground="{ThemeResource AppTextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Designer.DataSourceSummary}" FontSize="12"
                               Foreground="{ThemeResource AppMutedTextBrush}" VerticalAlignment="Center"/>
                    <Button Command="{Binding Designer.LoadDataSourceCommand}"
                            Padding="10,4" ToolTipService.ToolTip="Load CSV, Excel, or JSON data for mail merge">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xED25;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            <TextBlock Text="Load Data"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Command="{Binding Designer.PreviousPreviewRecordCommand}"
                            Width="28" Height="28" Padding="0"
                            IsEnabled="{Binding Designer.IsPreviewMode}"
                            ToolTipService.ToolTip="Previous record">
                        <FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <TextBlock Text="{Binding Designer.PreviewRecordText}" MinWidth="90"
                               TextAlignment="Center" VerticalAlignment="Center" FontSize="12"
                               Foreground="{ThemeResource AppMutedTextBrush}"/>
                    <Button Command="{Binding Designer.NextPreviewRecordCommand}"
                            Width="28" Height="28" Padding="0"
                            IsEnabled="{Binding Designer.IsPreviewMode}"
                            ToolTipService.ToolTip="Next record">
                        <FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="11"/>
                    </Button>
                    <Rectangle Width="1" Height="20" Fill="{ThemeResource AppBorderBrush}" Margin="6,0"/>
                    <Button Command="{Binding Designer.PrintWithDataCommand}"
                            Padding="12,4"
                            IsEnabled="{Binding Designer.HasLoadedDataSource}"
                            ToolTipService.ToolTip="Print selected records (or all records when none are selected)">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            <TextBlock Text="Print Data"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ Main content ══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240" MaxWidth="480"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── LEFT: Mappings + Preview ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="1"/>
                    <RowDefinition Height="320"/>
                </Grid.RowDefinitions>

                <!-- Mapping list -->
                <Grid Grid.Row="0"
                      Background="{ThemeResource AppSurfaceBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,8"
                            Background="{ThemeResource AppSurfaceAltBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Column Mappings" FontWeight="SemiBold" FontSize="13"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                    </Border>

                    <!-- Empty state: no data source loaded -->
                    <StackPanel Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Padding="24" Spacing="10"
                                Visibility="{Binding Designer.HasNoLoadedDataSource, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                  Foreground="{ThemeResource AppMutedTextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Load a data file to map its columns to canvas elements."
                                   TextWrapping="WrapWholeWords" TextAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource AppMutedTextBrush}"/>
                    </StackPanel>

                    <!-- Empty state: data loaded but no bindable elements -->
                    <StackPanel Grid.Row="1"
                                 VerticalAlignment="Center" HorizontalAlignment="Center"
                                 Padding="24" Spacing="10"
                                 Visibility="{Binding Designer.HasLoadedDataSourceButNoMergeBindings, Converter={StaticResource BoolToVisibility}}">
                        <FontIcon Glyph="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="36"
                                  Foreground="{ThemeResource AppMutedTextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="No Text or Barcode elements found on the canvas. Add them first in the Designer tab."
                                   TextWrapping="WrapWholeWords" TextAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource AppMutedTextBrush}"/>
                    </StackPanel>

                    <!-- Mapping items -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding Designer.HasMergeBindings, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl ItemsSource="{Binding Designer.MergeBindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10,7"
                                            BorderBrush="{ThemeResource AppBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="140"/>
                                            </Grid.ColumnDefinitions>

                                            <FontIcon Grid.Column="0"
                                                      Glyph="{Binding TypeGlyph}"
                                                      FontFamily="Segoe MDL2 Assets"
                                                      FontSize="13"
                                                      VerticalAlignment="Center"
                                                      Foreground="{ThemeResource AppGlyphBrush}"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DisplayName}"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTipService.ToolTip="{Binding DisplayName}"/>

                                            <ComboBox Grid.Column="2"
                                                      ItemsSource="{Binding AvailableColumns}"
                                                      SelectedItem="{Binding SelectedColumn, Mode=TwoWay}"
                                                      PlaceholderText="-- none --"
                                                      FontSize="11"
                                                      Padding="8,4"
                                                      HorizontalAlignment="Stretch"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- Splitter -->
                <Border Grid.Row="1" Background="{ThemeResource AppBorderBrush}"/>

                <!-- Merged preview -->
                <Grid Grid.Row="2"
                      Background="{ThemeResource AppSurfaceAltBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="12,6"
                            Background="{ThemeResource AppSurfaceAltBrush}"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <TextBlock Text="Merged Preview" FontWeight="SemiBold" FontSize="12"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                    </Border>

                    <Border Grid.Row="1" Margin="8"
                            Background="White"
                            BorderBrush="{ThemeResource AppBorderBrush}"
                            BorderThickness="1" CornerRadius="4">
                        <views:MergePreviewView/>
                    </Border>
                </Grid>
            </Grid>

            <!-- Column divider -->
            <Border Grid.Column="1" Background="{ThemeResource AppBorderBrush}"/>

            <!-- ── RIGHT: Data grid ── -->
            <Grid Grid.Column="2" Background="{ThemeResource AppSurfaceBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,8"
                        Background="{ThemeResource AppSurfaceAltBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="Data Records" FontWeight="SemiBold" FontSize="13"
                               Foreground="{ThemeResource AppTextBrush}"/>
                </Border>

                <!-- Empty state -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Padding="24" Spacing="10"
                            Visibility="{Binding Designer.HasNoLoadedDataSource, Converter={StaticResource BoolToVisibility}}">
                    <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                              Foreground="{ThemeResource AppMutedTextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="No data loaded. Click Load Data above to import CSV, Excel, or JSON."
                               TextWrapping="WrapWholeWords" TextAlignment="Center"
                               Foreground="{ThemeResource AppMutedTextBrush}"/>
                </StackPanel>

                <sfgrid:SfDataGrid x:Name="CsvDataGrid"
                                   Grid.Row="1"
                                   AutoGenerateColumnsMode="ResetAll"
                                   AllowEditing="False"
                                   AllowFiltering="True"
                                   AllowSorting="True"
                                   SelectionMode="Extended"
                                   NavigationMode="Row"
                                   SelectedItem="{Binding Designer.SelectedDataMergeRow, Mode=TwoWay}"
                                   SelectionChanged="OnGridSelectionChanged"
                                   GridLinesVisibility="Both"
                                   HeaderRowHeight="36"
                                   RowHeight="32"
                                   Visibility="{Binding Designer.HasLoadedDataSource, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
