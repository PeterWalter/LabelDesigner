<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LabelDesigner.App.Views.DataMergePaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sfgrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="{ThemeResource AppSurfaceBrush}"
            BorderBrush="{ThemeResource AppBorderBrush}"
            BorderThickness="0">
        <Grid MinHeight="220">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource AppSurfaceAltBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                  Foreground="{ThemeResource AppGlyphBrush}"/>
                        <TextBlock Text="Data Merge"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                        <TextBlock Text="{Binding Designer.DataSourceSummary}"
                                   FontSize="12"
                                   Foreground="{ThemeResource AppMutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding Designer.ShowDesignerWorkspaceCommand}"
                            Width="28" Height="28" Padding="0"
                            ToolTipService.ToolTip="Return to the designer tab">
                        <FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="10,10,10,0"
                    Padding="10"
                    Background="{ThemeResource AppSurfaceAltBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="How to mail merge"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                        <TextBlock Text="{Binding Designer.DataMergeActionSummary}"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource AppMutedTextBrush}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="{Binding Designer.DataMergeTargetSummary}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                        <TextBlock Text="{Binding Designer.SelectedDataFieldToken}"
                                   FontFamily="Consolas"
                                   Foreground="{ThemeResource AppActiveLayerAccentBrush}"/>
                        <TextBlock Text="Use Preview or Print to open the Windows print preview window, review every page, and choose the printer."
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource AppMutedTextBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="2" Padding="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Selected Column"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{ThemeResource AppMutedTextBrush}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Designer.AvailableDataFields}"
                          SelectedItem="{Binding Designer.SelectedDataField, Mode=TwoWay}"
                          PlaceholderText="Choose CSV column"/>
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Command="{Binding Designer.BindSelectedFieldToTextCommand}"
                        IsEnabled="{Binding Designer.CanBindSelectedDataFieldToText}"
                        ToolTipService.ToolTip="Bind the selected CSV column to the selected text element">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        <TextBlock Text="Bind to Text"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Command="{Binding Designer.BindSelectedFieldToBarcodeCommand}"
                        IsEnabled="{Binding Designer.CanBindSelectedDataFieldToBarcode}"
                        ToolTipService.ToolTip="Bind the selected CSV column to the selected barcode element">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        <TextBlock Text="Bind to Barcode"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="4"
                            Margin="12,0,0,0"
                            VerticalAlignment="Center"
                            Text="The loaded CSV is shown below. Edit rows directly, filter by any column, and bind the selected column to the selected Barcode or Text element."
                            TextWrapping="WrapWholeWords"
                            Foreground="{ThemeResource AppMutedTextBrush}"/>
            </Grid>

            <sfgrid:SfDataGrid Grid.Row="3"
                               Margin="10,0,10,10"
                               ItemsSource="{Binding Designer.DataMergeItemsSource}"
                               AllowEditing="True"
                               AllowFiltering="True"
                               ShowGroupDropArea="True"
                               AutoGenerateColumnsMode="ResetAll"/>
        </Grid>
    </Border>
</UserControl>
