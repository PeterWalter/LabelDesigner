<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LabelDesigner.App.Views.DataMergePaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:LabelDesigner.App.Converters"
    xmlns:sfgrid="using:Syncfusion.UI.Xaml.DataGrid"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Border Background="{ThemeResource AppSurfaceBrush}"
            BorderBrush="{ThemeResource AppBorderBrush}"
            BorderThickness="0,1,0,0"
            Visibility="{Binding Designer.IsDataMergePaneOpen, Converter={StaticResource BoolToVisibility}}">
        <Grid MinHeight="220" MaxHeight="340">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{ThemeResource AppSurfaceAltBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="10,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xE8F1;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                  Foreground="{ThemeResource AppGlyphBrush}"/>
                        <TextBlock Text="Data Merge"
                                   FontWeight="SemiBold"
                                   FontSize="13"
                                   Foreground="{ThemeResource AppTextBrush}"/>
                        <TextBlock Text="{Binding Designer.DataSourceSummary}"
                                   FontSize="12"
                                   Foreground="{ThemeResource AppMutedTextBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Command="{Binding Designer.ToggleDataMergePaneCommand}"
                            Width="28" Height="28" Padding="0"
                            ToolTipService.ToolTip="Hide data merge panel">
                        <FontIcon Glyph="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Padding="10,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Selected Column"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{ThemeResource AppMutedTextBrush}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Designer.AvailableDataFields}"
                          SelectedItem="{Binding Designer.SelectedDataField, Mode=TwoWay}"
                          PlaceholderText="Choose CSV column"/>
                <Button Grid.Column="2"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Command="{Binding Designer.BindSelectedFieldToTextCommand}"
                        IsEnabled="{Binding Designer.CanBindSelectedDataFieldToText}"
                        ToolTipService.ToolTip="Bind the selected CSV column to the selected text element">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        <TextBlock Text="Bind to Text"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3"
                        Margin="8,0,0,0"
                        Padding="10,4"
                        Command="{Binding Designer.BindSelectedFieldToBarcodeCommand}"
                        IsEnabled="{Binding Designer.CanBindSelectedDataFieldToBarcode}"
                        ToolTipService.ToolTip="Bind the selected CSV column to the selected barcode element">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8A1;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                        <TextBlock Text="Bind to Barcode"/>
                    </StackPanel>
                </Button>
                <TextBlock Grid.Column="4"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           Text="Edit cells directly. Drag column headers into the group area to group, and use header filters to narrow the view."
                           TextWrapping="WrapWholeWords"
                           Foreground="{ThemeResource AppMutedTextBrush}"/>
            </Grid>

            <sfgrid:SfDataGrid Grid.Row="2"
                               Margin="10,0,10,10"
                               ItemsSource="{Binding Designer.DataMergeItemsSource}"
                               AllowEditing="True"
                               AllowFiltering="True"
                               ShowGroupDropArea="True"
                               AutoGenerateColumnsMode="ResetAll"/>
        </Grid>
    </Border>
</UserControl>
