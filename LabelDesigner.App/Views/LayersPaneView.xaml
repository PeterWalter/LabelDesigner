<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LabelDesigner.App.Views.LayersPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="6,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HeaderText" Grid.Column="0" Text="Layers"
                        FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" Foreground="#2B2B2B"/>
                    <ToggleButton Grid.Column="1" x:Name="CollapseToggle"
                        Width="28" Height="28" Padding="0" IsChecked="False"
                        Checked="OnCollapseToggleChanged" Unchecked="OnCollapseToggleChanged"
                        ToolTipService.ToolTip="Collapse Layers panel">
                        <FontIcon x:Name="CollapseIcon" Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </ToggleButton>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" x:Name="ContentArea" Padding="6,4">
                <ItemsControl ItemsSource="{Binding Designer.Layers.Layers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="#333"/>
                                <ItemsControl ItemsSource="{Binding Children}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,1,0,1" PointerPressed="OnLayerItemClick" Padding="3,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}"
                                                    FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                    FontSize="11" VerticalAlignment="Center" Foreground="#555"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
