<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="LabelDesigner.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" Margin="32,24" Spacing="8" HorizontalAlignment="Left">

            <TextBlock Text="Settings" FontSize="24" FontWeight="SemiBold"
                       Foreground="{ThemeResource AppTextBrush}" Margin="0,0,0,16"/>

            <!-- Measurement card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Measurement" FontWeight="SemiBold" FontSize="15"
                               Foreground="{ThemeResource AppTextBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Ruler units"
                                       FontSize="14" Foreground="{ThemeResource AppTextBrush}"/>
                            <TextBlock Text="Units shown on canvas rulers"
                                       FontSize="12" Foreground="{ThemeResource AppMutedTextBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="RulerUnitCombo"
                                  Width="160" SelectionChanged="OnRulerUnitChanged">
                            <ComboBoxItem Content="Millimeters"/>
                            <ComboBoxItem Content="Centimeters"/>
                            <ComboBoxItem Content="Inches"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Canvas card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Canvas" FontWeight="SemiBold" FontSize="15"
                               Foreground="{ThemeResource AppTextBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Show snap grid"
                                       FontSize="14" Foreground="{ThemeResource AppTextBrush}"/>
                            <TextBlock Text="Display alignment grid on the design canvas"
                                       FontSize="12" Foreground="{ThemeResource AppMutedTextBrush}"/>
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1" x:Name="SnapGridToggle"
                                      OnContent="" OffContent=""
                                      Toggled="OnSnapGridToggled"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Label stock preset"
                                       FontSize="14" Foreground="{ThemeResource AppTextBrush}"/>
                            <TextBlock Text="Pre-defined label page dimensions"
                                       FontSize="12" Foreground="{ThemeResource AppMutedTextBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" Width="220"
                                  DisplayMemberPath="DisplayName"
                                  SelectedValuePath="Id"
                                  ItemsSource="{Binding Designer.LabelStockPresets}"
                                  SelectedValue="{Binding Designer.SelectedLabelStockPresetId, Mode=TwoWay}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Appearance card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16" Margin="0,0,0,8">
                <StackPanel Spacing="12">
                    <TextBlock Text="Appearance" FontWeight="SemiBold" FontSize="15"
                               Foreground="{ThemeResource AppTextBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Application theme"
                                       FontSize="14" Foreground="{ThemeResource AppTextBrush}"/>
                            <TextBlock Text="Choose between light, dark, or follow system setting"
                                       FontSize="12" Foreground="{ThemeResource AppMutedTextBrush}"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="ThemeCombo"
                                  Width="160" SelectionChanged="OnThemeChanged">
                            <ComboBoxItem Content="System default"/>
                            <ComboBoxItem Content="Light"/>
                            <ComboBoxItem Content="Dark"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- About card -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="20,16">
                <StackPanel Spacing="4">
                    <TextBlock Text="About" FontWeight="SemiBold" FontSize="15"
                               Foreground="{ThemeResource AppTextBrush}"/>
                    <TextBlock Text="LabelDesigner" FontSize="14" Foreground="{ThemeResource AppTextBrush}"/>
                    <TextBlock FontSize="12" Foreground="{ThemeResource AppMutedTextBrush}">
                        <Run Text="Professional label design and print software."/>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
