<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="LabelDesigner.App.Views.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Application Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <ScrollViewer MaxHeight="600" MinWidth="360">
        <StackPanel Spacing="12" Padding="4,8">

            <TextBlock Text="Measurement" FontWeight="SemiBold" FontSize="14"/>

            <TextBlock Text="Ruler Units" FontSize="12" Foreground="{ThemeResource AppSubtleTextBrush}"/>
            <ComboBox x:Name="RulerUnitCombo" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="Millimeters" Tag="0"/>
                <ComboBoxItem Content="Centimeters" Tag="1"/>
                <ComboBoxItem Content="Inches" Tag="2"/>
            </ComboBox>

            <TextBlock Text="Canvas" FontWeight="SemiBold" FontSize="14" Margin="0,8,0,0"/>

            <ToggleSwitch x:Name="SnapGridToggle"
                Header="Show snap grid"
                OnContent="On" OffContent="Off"/>

            <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="14" Margin="0,8,0,0"/>

            <TextBlock Text="Application Theme" FontSize="12" Foreground="{ThemeResource AppSubtleTextBrush}"/>
            <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Stretch">
                <ComboBoxItem Content="System Default" Tag="0"/>
                <ComboBoxItem Content="Light" Tag="1"/>
                <ComboBoxItem Content="Dark" Tag="2"/>
            </ComboBox>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
