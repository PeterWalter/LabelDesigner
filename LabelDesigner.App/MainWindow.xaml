<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LabelDesigner.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ribbon="using:Syncfusion.UI.Xaml.Ribbon"
    xmlns:views="using:LabelDesigner.App.Views"
    xmlns:controls="using:LabelDesigner.App.Controls"
    xmlns:converters="using:LabelDesigner.App.Converters"
    xmlns:vm="using:LabelDesigner.App.ViewModels"
   
    mc:Ignorable="d">

    <!-- ROOT LAYOUT -->
    <Grid Name="RootGrid" Background="#F3F3F3">

        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </Grid.Resources>

        <!-- ROWS -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Ribbon -->
            <RowDefinition Height="20"/>
            <!-- Top ruler -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ========================= -->
        <!-- RIBBON -->
        <!-- ========================= -->
        <ribbon:SfRibbon>

            <!-- NORMAL TABS -->
            <ribbon:SfRibbon.Tabs>
                <ribbon:RibbonTab Header="Home"/>
            </ribbon:SfRibbon.Tabs>

            <!-- CONTEXTUAL -->
            <ribbon:SfRibbon.ContextualTabGroups>

                <!-- BARCODE -->
                <ribbon:RibbonContextualTabGroup
            Visibility="{Binding Designer.IsBarcodeSelected, Converter={StaticResource BoolToVisibility}}">

                    <ribbon:RibbonContextualTabGroup.Tabs>
                        <ribbon:RibbonTab Header="Barcode Format">
                            <ribbon:RibbonGroup Header="Barcode">
                                <ribbon:RibbonButton Content="Rotate"
                                             Command="{Binding Designer.RotateCommand}"/>
                            </ribbon:RibbonGroup>
                        </ribbon:RibbonTab>
                    </ribbon:RibbonContextualTabGroup.Tabs>

                </ribbon:RibbonContextualTabGroup>

            </ribbon:SfRibbon.ContextualTabGroups>

        </ribbon:SfRibbon>

        <!-- ========================= -->
        <!-- TOP RULER -->
        <!-- ========================= -->
        <controls:RulerControl Grid.Row="1" />

        <!-- ========================= -->
        <!-- MAIN DESIGN AREA -->
        <!-- ========================= -->
        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <!-- Left ruler -->
                <ColumnDefinition Width="*"/>
                <!-- Canvas -->
            </Grid.ColumnDefinitions>

            <!-- LEFT RULER -->
            <controls:RulerControl Grid.Column="0"
                               x:Name="LeftRuler"/>

            <!-- DESIGNER CANVAS -->
            <views:DesignerCanvasView Grid.Column="1"/>

        </Grid>

    </Grid>
</Window>
