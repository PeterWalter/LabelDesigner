<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LabelDesigner.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ribbon="using:Syncfusion.UI.Xaml.Ribbon"
    xmlns:views="using:LabelDesigner.App.Views"
    xmlns:controls="using:LabelDesigner.App.Controls"
    xmlns:converters="using:LabelDesigner.App.Converters"
    mc:Ignorable="d"
    Title="LabelDesigner">

    <Grid Name="RootGrid" Background="{ThemeResource AppShellBackgroundBrush}">

        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
            <converters:ToolModeToBackgroundConverter x:Key="ToolModeToBackground"/>
            <Style TargetType="TextBox" x:Key="PropBox">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4,0"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <ribbon:SfRibbon Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1">

            <ribbon:SfRibbon.Tabs>
 
                <ribbon:RibbonTab Header="File">
                    <ribbon:RibbonGroup Header="Document">
                        <ribbon:RibbonButton Content="New" Command="{Binding Designer.NewDocumentCommand}"
                            AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Create new document (Ctrl+N)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8A5;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Open" Command="{Binding Designer.OpenDocumentCommand}"
                            AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Open document (Ctrl+O)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Save" Command="{Binding Designer.SaveDocumentCommand}"
                            AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Save document (Ctrl+S)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74E;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Save As" Command="{Binding Designer.SaveAsDocumentCommand}"
                            AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Save document as...">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE78C;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Data">
                        <ribbon:RibbonButton Content="Select CSV" Command="{Binding Designer.LoadDataSourceCommand}"
                            AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Select CSV data source file">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8F4;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Recent">
                        <ribbon:RibbonButton Content="Open Recent" Command="{Binding Designer.OpenSelectedRecentCommand}"
                            ToolTipService.ToolTip="Open the selected recent file">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE81C;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                </ribbon:RibbonTab>

                <ribbon:RibbonTab Header="Home" Background="{ThemeResource AppSurfaceBrush}">
                <ribbon:RibbonGroup Header="Elements" Background="{ThemeResource AppSurfaceBrush}">
                        <ribbon:RibbonButton 
                            Content="Select" 
                            Command="{Binding Designer.SelectToolCommand}" 
                            AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Select tool — click to select elements (S)"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=Select}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8B0;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton 
                            Content="Barcode" 
                            Command="{Binding Designer.AddBarcodeCommand}"
                            ToolTipService.ToolTip="Add barcode element (B)"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=PlaceBarcode}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xF3BE;" FontFamily="Segoe Fluent Icons"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton 
                            Content="Text" 
                            Command="{Binding Designer.AddTextCommand}"
                            ToolTipService.ToolTip="Add text element (T)"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=PlaceText}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8D2;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton 
                            Content="Shape" 
                            Command="{Binding Designer.AddShapeCommand}"
                            ToolTipService.ToolTip="Add rectangle shape"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=PlaceShape}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xEC4E;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton 
                            Content="Line" 
                            Command="{Binding Designer.AddLineCommand}"
                            ToolTipService.ToolTip="Add line element (L)"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=PlaceLine}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE751;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton 
                            Content="Image" 
                            Command="{Binding Designer.AddImageCommand}"
                            ToolTipService.ToolTip="Insert image from file"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=PlaceImage}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton 
                            Content="SVG" 
                            Command="{Binding Designer.AddSvgCommand}"
                            ToolTipService.ToolTip="Import SVG vector file"
                            Background="{Binding Designer.ActiveTool, Converter={StaticResource ToolModeToBackground}, ConverterParameter=PlaceSvg}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8A5;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Delete" Command="{Binding Designer.DeleteSelectedCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Delete selected element (Del)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Arrange">
                        <ribbon:RibbonButton Content="Group" Command="{Binding Designer.GroupSelectedCommand}"
                            ToolTipService.ToolTip="Group selected elements (Ctrl+G)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xF5B2;" FontFamily="Segoe Fluent Icons"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Ungroup" Command="{Binding Designer.UngroupSelectedCommand}"
                            ToolTipService.ToolTip="Ungroup elements (Ctrl+Shift+G)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xF5B3;" FontFamily="Segoe Fluent Icons"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Move">
                        <ribbon:RibbonButton Content="Left" Command="{Binding Designer.MoveLeftCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Move element left (←)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE72B;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Right" Command="{Binding Designer.MoveRightCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Move element right (→)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE72A;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Up" Command="{Binding Designer.MoveUpCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Move element up (↑)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE70E;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Down" Command="{Binding Designer.MoveDownCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Move element down (↓)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE70D;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Scale">
                        <ribbon:RibbonButton Content="Larger" Command="{Binding Designer.ScaleUpCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Scale element larger">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE740;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Smaller" Command="{Binding Designer.ScaleDownCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Scale element smaller">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE741;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Align">
                        <ribbon:RibbonButton Content="Left" Command="{Binding Designer.AlignLeftCommand}"
                            ToolTipService.ToolTip="Align left edges">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE0E6;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Center" Command="{Binding Designer.AlignCenterCommand}"
                            ToolTipService.ToolTip="Align centers horizontally">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8E3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Right" Command="{Binding Designer.AlignRightCommand}"
                            ToolTipService.ToolTip="Align right edges">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE0E8;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Top" Command="{Binding Designer.AlignTopCommand}"
                            ToolTipService.ToolTip="Align top edges">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE14B;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Bottom" Command="{Binding Designer.AlignBottomCommand}"
                            ToolTipService.ToolTip="Align bottom edges">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE14C;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Dist H" Command="{Binding Designer.DistributeHorizontalCommand}"
                            ToolTipService.ToolTip="Distribute elements evenly — horizontal">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE134;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Dist V" Command="{Binding Designer.DistributeVerticalCommand}"
                            ToolTipService.ToolTip="Distribute elements evenly — vertical">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE135;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Clipboard">
                        <ribbon:RibbonButton Content="Copy" Command="{Binding Designer.CopySelectedCommand}"
                            AutomationProperties.Name="Copy selected element (Ctrl+C)"
                            ToolTipService.ToolTip="Copy (Ctrl+C)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8C8;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                            <ribbon:RibbonButton.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="C"/>
                            </ribbon:RibbonButton.KeyboardAccelerators>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Paste" Command="{Binding Designer.PasteElementCommand}"
                            AutomationProperties.Name="Paste element (Ctrl+V)"
                            ToolTipService.ToolTip="Paste (Ctrl+V)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE77F;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                            <ribbon:RibbonButton.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="V"/>
                            </ribbon:RibbonButton.KeyboardAccelerators>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="View">
                        <ribbon:RibbonButton Content="Zoom In" Command="{Binding Designer.ZoomInCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Zoom in (Ctrl++)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8A7;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Zoom Out" Command="{Binding Designer.ZoomOutCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Zoom out (Ctrl+-)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE71E;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Fit" Command="{Binding Designer.ZoomToFitCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Fit page to window (Ctrl+0)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE950;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Page">
                        <ribbon:RibbonButton Content="A4" Command="{Binding Designer.SetPageA4Command}"
                            ToolTipService.ToolTip="Set page size to A4 (210×297 mm)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="A5" Command="{Binding Designer.SetPageA5Command}"
                            ToolTipService.ToolTip="Set page size to A5 (148×210 mm)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="A3" Command="{Binding Designer.SetPageA3Command}"
                            ToolTipService.ToolTip="Set page size to A3 (297×420 mm)">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Flip" Command="{Binding Designer.ToggleOrientationCommand}"
                            ToolTipService.ToolTip="Toggle portrait / landscape orientation">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7AD;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="4×5" Command="{Binding Designer.SetPageLabel4x5Command}"
                            ToolTipService.ToolTip="Label stock: 4×5 inches">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="6×4" Command="{Binding Designer.SetPageLabel6x4Command}"
                            ToolTipService.ToolTip="Label stock: 6×4 inches">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="8×3" Command="{Binding Designer.SetPageLabel8x3Command}"
                            ToolTipService.ToolTip="Label stock: 8×3 inches">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Rotate">
                        <ribbon:RibbonButton Content="Rot 90°" Command="{Binding Designer.RotateElementCommand}" AllowedSizeModes="Large"
                            ToolTipService.ToolTip="Rotate selected element 90° clockwise">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C8;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Data">
                        <ribbon:RibbonButton Content="1/Page" Command="{Binding Designer.SetMergeModeOneRecordPerPageCommand}"
                            ToolTipService.ToolTip="Merge mode: one CSV record per printed page">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8EF;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Multi/Page" Command="{Binding Designer.SetMergeModeMultipleRecordsPerPageCommand}"
                            ToolTipService.ToolTip="Merge mode: multiple CSV records tiled per page">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xF16B;" FontFamily="Segoe Fluent Icons"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Print All" Command="{Binding Designer.PrintWithDataCommand}"
                            ToolTipService.ToolTip="Print all CSV records using current merge mode">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE749;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Preview">
                        <ribbon:RibbonButton Content="Preview" Command="{Binding Designer.PreviewPrintCommand}"
                            ToolTipService.ToolTip="Show print preview">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Export">
                        <ribbon:RibbonButton Content="Print" Command="{Binding Designer.PrintCommand}"
                            ToolTipService.ToolTip="Print label to printer">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE749;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="PDF" Command="{Binding Designer.ExportPdfCommand}"
                            ToolTipService.ToolTip="Export label as PDF">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xEA90;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="PNG" Command="{Binding Designer.ExportPngCommand}"
                            ToolTipService.ToolTip="Export label as PNG image">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                </ribbon:RibbonTab>

            </ribbon:SfRibbon.Tabs>

            <ribbon:SfRibbon.ContextualTabGroups>
                <ribbon:RibbonContextualTabGroup
            Visibility="{Binding Designer.IsBarcodeSelected, Converter={StaticResource BoolToVisibility}}">
                    <ribbon:RibbonContextualTabGroup.Tabs>
                        <ribbon:RibbonTab Header="Barcode">
                            <ribbon:RibbonGroup Header="Symbology">
                                <StackPanel Spacing="2" VerticalAlignment="Center" Padding="4,0">
                                    <TextBlock Text="Barcode Type" FontSize="10"
                                        Foreground="{ThemeResource AppMutedTextBrush}"/>
                                    <ComboBox x:Name="RibbonBarcodeSymbologyCombo"
                                        Width="120"
                                        SelectedIndex="{Binding Designer.Properties.BarcodeSymbologyIndex, Mode=TwoWay}"
                                        ToolTipService.ToolTip="Select barcode symbology (Code128, QR, EAN, etc.)">
                                        <ComboBoxItem Content="Code 128"/>
                                        <ComboBoxItem Content="Code 39"/>
                                        <ComboBoxItem Content="QR Code"/>
                                        <ComboBoxItem Content="EAN-13"/>
                                        <ComboBoxItem Content="EAN-8"/>
                                        <ComboBoxItem Content="UPC-A"/>
                                        <ComboBoxItem Content="DataMatrix"/>
                                        <ComboBoxItem Content="PDF417"/>
                                        <ComboBoxItem Content="Aztec"/>
                                        <ComboBoxItem Content="ITF"/>
                                    </ComboBox>
                                </StackPanel>
                            </ribbon:RibbonGroup>
                            <ribbon:RibbonGroup Header="Text Position">
                                <ribbon:RibbonButton Content="Top" Command="{Binding Designer.SetTextTopCommand}"
                                    ToolTipService.ToolTip="Place barcode text above bars">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74A;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                                <ribbon:RibbonButton Content="Bottom" Command="{Binding Designer.SetTextBottomCommand}"
                                    ToolTipService.ToolTip="Place barcode text below bars">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74B;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                                <ribbon:RibbonButton Content="Left" Command="{Binding Designer.SetTextLeftCommand}"
                                    ToolTipService.ToolTip="Place barcode text to the left">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                                <ribbon:RibbonButton Content="Right" Command="{Binding Designer.SetTextRightCommand}"
                                    ToolTipService.ToolTip="Place barcode text to the right">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                            </ribbon:RibbonGroup>
                            <ribbon:RibbonGroup Header="Data Merge">
                                <StackPanel Spacing="2" VerticalAlignment="Center" Padding="4,0">
                                    <TextBlock Text="Bind to CSV Field" FontSize="10"
                                        Foreground="{ThemeResource AppMutedTextBrush}"/>
                                    <ComboBox x:Name="BarcodeFieldCombo"
                                        Width="150"
                                        ItemsSource="{Binding Designer.AvailableDataFields}"
                                        PlaceholderText="Select field..."
                                        SelectionChanged="OnBarcodeFieldSelected"
                                        ToolTipService.ToolTip="Set barcode value to {{FieldName}} — replaced per CSV row at print time"/>
                                </StackPanel>
                            </ribbon:RibbonGroup>
                        </ribbon:RibbonTab>
                    </ribbon:RibbonContextualTabGroup.Tabs>
                </ribbon:RibbonContextualTabGroup>

                <ribbon:RibbonContextualTabGroup
            Visibility="{Binding Designer.IsTextSelected, Converter={StaticResource BoolToVisibility}}">
                    <ribbon:RibbonContextualTabGroup.Tabs>
                        <ribbon:RibbonTab Header="Text">
                            <ribbon:RibbonGroup Header="Data Merge">
                                <StackPanel Spacing="2" VerticalAlignment="Center" Padding="4,0">
                                    <TextBlock Text="Bind to CSV Field" FontSize="10"
                                        Foreground="{ThemeResource AppMutedTextBrush}"/>
                                    <ComboBox x:Name="TextFieldCombo"
                                        Width="150"
                                        ItemsSource="{Binding Designer.AvailableDataFields}"
                                        PlaceholderText="Select field..."
                                        SelectionChanged="OnTextFieldSelected"
                                        ToolTipService.ToolTip="Set text to {{FieldName}} — replaced per CSV row at print time"/>
                                </StackPanel>
                            </ribbon:RibbonGroup>
                        </ribbon:RibbonTab>
                    </ribbon:RibbonContextualTabGroup.Tabs>
                </ribbon:RibbonContextualTabGroup>
            </ribbon:SfRibbon.ContextualTabGroups>

        </ribbon:SfRibbon>

        <Border Grid.Row="1" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1" Padding="8,4">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ToggleButton x:Name="LayersToggle" Content="Layers" IsChecked="True"
                    Padding="6,2"
                    Checked="OnLayersPaneToggled" Unchecked="OnLayersPaneToggled"
                    ToolTipService.ToolTip="Show/hide Layers panel"/>
                <ToggleButton x:Name="PropertiesToggle" Content="Properties" IsChecked="True"
                    Padding="6,2"
                    Checked="OnPropertiesPaneToggled" Unchecked="OnPropertiesPaneToggled"
                    ToolTipService.ToolTip="Show/hide Properties panel"/>
                <Button Content="Reset Layout" Click="OnResetLayout"
                    Padding="6,2"
                    ToolTipService.ToolTip="Restore default panel layout"/>
                <Button Content="Settings" Click="OnSettingsClicked"
                    Padding="6,2"
                    ToolTipService.ToolTip="Application Settings"/>
                <ToggleButton x:Name="SnapGridToggle" Content="Grid" IsChecked="True"
                    Padding="6,2"
                    Checked="OnSnapGridToggled" Unchecked="OnSnapGridToggled"
                    ToolTipService.ToolTip="Show snap grid on canvas"/>
                <TextBlock Text="Ruler Units" VerticalAlignment="Center"/>
                <ComboBox x:Name="RulerUnitComboBox" Width="90" SelectionChanged="OnRulerUnitChanged" SelectedIndex="0">
                    <ComboBoxItem Content="mm" Tag="Millimeters"/>
                    <ComboBoxItem Content="cm" Tag="Centimeters"/>
                    <ComboBoxItem Content="in" Tag="Inches"/>
                </ComboBox>
                <TextBlock x:Name="StockPresetLabel" Text="Stock Preset" VerticalAlignment="Center"/>
                <ComboBox Width="220"
                    DisplayMemberPath="DisplayName"
                    SelectedValuePath="Id"
                    ItemsSource="{Binding Designer.LabelStockPresets}"
                    SelectedValue="{Binding Designer.SelectedLabelStockPresetId, Mode=TwoWay}" />
                <TextBlock x:Name="RecentFilesLabel" Text="Recent Files" VerticalAlignment="Center"/>
                <ComboBox Width="220"
                    ItemsSource="{Binding Designer.RecentFiles}"
                    SelectedItem="{Binding Designer.SelectedRecentFile, Mode=TwoWay}" />
                <Button x:Name="OpenRecentButton" Content="Open Recent"
                    Command="{Binding Designer.OpenSelectedRecentCommand}"
                    Padding="6,2"
                    ToolTipService.ToolTip="Open the selected recent file"/>

                <!-- ── Merge Preview Navigator (visible when CSV loaded) ── -->
                <Border Width="1" Background="{ThemeResource AppBorderBrush}"
                    Visibility="{Binding Designer.IsPreviewMode, Converter={StaticResource BoolToVisibility}}"
                    Margin="4,2"/>
                <Button Content="◄" Command="{Binding Designer.PreviousPreviewRecordCommand}"
                    Padding="6,2" FontSize="12"
                    Visibility="{Binding Designer.IsPreviewMode, Converter={StaticResource BoolToVisibility}}"
                    ToolTipService.ToolTip="Previous CSV record"/>
                <TextBlock Text="{Binding Designer.PreviewRecordText}"
                    VerticalAlignment="Center" FontSize="11"
                    Foreground="{ThemeResource AppAccentBrush}"
                    Visibility="{Binding Designer.IsPreviewMode, Converter={StaticResource BoolToVisibility}}"/>
                <Button Content="►" Command="{Binding Designer.NextPreviewRecordCommand}"
                    Padding="6,2" FontSize="12"
                    Visibility="{Binding Designer.IsPreviewMode, Converter={StaticResource BoolToVisibility}}"
                    ToolTipService.ToolTip="Next CSV record"/>
                <Button Content="✕ Preview" Command="{Binding Designer.ExitPreviewModeCommand}"
                    Padding="6,2" FontSize="11"
                    Visibility="{Binding Designer.IsPreviewMode, Converter={StaticResource BoolToVisibility}}"
                    ToolTipService.ToolTip="Exit merge preview mode"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LayerColumn" Width="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition x:Name="PropertiesColumn" Width="220"/>
            </Grid.ColumnDefinitions>

            <views:LayersPaneView Grid.Column="0" x:Name="LayersPane"
                AutomationProperties.Name="Layers panel"/>

            <Border Grid.Column="1" x:Name="SplitterLeft" Background="{ThemeResource AppSurfaceAltBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,1,0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                AutomationProperties.Name="Resize Layers panel"
                PointerPressed="OnSplitterPressed" PointerMoved="OnSplitterMoved" PointerReleased="OnSplitterReleased"/>

            <!-- Canvas zone: rulers wrap the canvas -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- top-left corner spacer -->
                <Border Grid.Row="0" Grid.Column="0" Background="{ThemeResource AppSurfaceSubtleBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,1,1"/>

                <!-- horizontal ruler -->
                <controls:RulerControl Grid.Row="0" Grid.Column="1" x:Name="HorizontalRuler"
                    Viewport="{Binding Designer.Viewport}" PixelsPerMm="{Binding Designer.PixelsPerMm}" Background="{ThemeResource AppSurfaceSubtleBrush}"/>

                <!-- vertical ruler -->
                <controls:RulerControl Grid.Row="1" Grid.Column="0" x:Name="LeftRuler" IsVertical="True"
                    Viewport="{Binding Designer.Viewport}" PixelsPerMm="{Binding Designer.PixelsPerMm}" Background="{ThemeResource AppSurfaceSubtleBrush}"/>

                <!-- canvas -->
                <views:DesignerCanvasView Grid.Row="1" Grid.Column="1"
                    AutomationProperties.Name="Label design canvas"
                    AutomationProperties.HelpText="Use arrow keys to nudge selected elements. Delete to remove. Ctrl+Z to undo."/>
            </Grid>

            <Border Grid.Column="3" x:Name="SplitterRight" Background="{ThemeResource AppSurfaceAltBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1,0,0,0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                AutomationProperties.Name="Resize Properties panel"
                PointerPressed="OnSplitterPressed" PointerMoved="OnSplitterMoved" PointerReleased="OnSplitterReleased"/>

            <views:PropertiesPaneView Grid.Column="4" x:Name="PropertiesPane"/>
        </Grid>

        <Border Grid.Row="3" Background="{ThemeResource AppSurfaceBrush}" BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,1,0,0" Padding="4,0"
            AutomationProperties.Name="Status bar">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Designer.RulerUnitText}" Margin="6,0,2,0" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource AppStatusTextBrush}"
                    AutomationProperties.Name="Ruler unit"/>
                <TextBlock Grid.Column="1" Text="|" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource AppStatusSeparatorBrush}" IsHitTestVisible="False"/>
                <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource AppStatusTextBrush}" Margin="4,0" Text="{Binding Designer.SnapStateText}"
                    AutomationProperties.Name="Snap state"/>
                <TextBlock Grid.Column="3" Text="|" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource AppStatusSeparatorBrush}" IsHitTestVisible="False"/>
                <TextBlock Grid.Column="4" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource AppStatusTextBrush}" Margin="4,0" Text="{Binding Designer.ZoomText}"
                    AutomationProperties.Name="Zoom level"/>
                <Button Grid.Column="6" Content="-" Margin="1,0" Padding="0" MinWidth="22" Height="20" FontSize="14"
                    Command="{Binding Designer.ZoomOutCommand}"
                    AutomationProperties.Name="Zoom out"
                    ToolTipService.ToolTip="Zoom out (Ctrl+-)"/>
                <Button Grid.Column="7" Content="+" Margin="1,0" Padding="0" MinWidth="22" Height="20" FontSize="14"
                    Command="{Binding Designer.ZoomInCommand}"
                    AutomationProperties.Name="Zoom in"
                    ToolTipService.ToolTip="Zoom in (Ctrl++)"/>
                <Button Grid.Column="8" Content="Fit" Margin="1,0" Padding="4,0" Height="20" FontSize="11"
                    Command="{Binding Designer.ZoomToFitCommand}"
                    AutomationProperties.Name="Zoom to fit"
                    ToolTipService.ToolTip="Zoom to fit (Ctrl+0)"/>
                <TextBlock Grid.Column="9" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource AppStatusTextBrush}" Margin="8,0,0,0" Text="{Binding Designer.CursorText}"
                    AutomationProperties.Name="Cursor position"/>
                <TextBlock Grid.Column="10" FontSize="12" VerticalAlignment="Center" Foreground="{ThemeResource AppStatusTextBrush}" Margin="12,0,6,0" Text="{Binding Designer.ElementsText}"
                    AutomationProperties.Name="Element count"/>
            </Grid>
        </Border>

    </Grid>
</Window>
