<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LabelDesigner.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ribbon="using:Syncfusion.UI.Xaml.Ribbon"
    xmlns:views="using:LabelDesigner.App.Views"
    xmlns:controls="using:LabelDesigner.App.Controls"
    xmlns:converters="using:LabelDesigner.App.Converters"
    mc:Ignorable="d"
    Title="LabelDesigner">

    <Grid Name="RootGrid" Background="#F0F2F5">

        <Grid.Resources>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:ColorToBrushConverter x:Key="ColorToBrush"/>
            <Style TargetType="TextBox" x:Key="PropBox">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="BorderBrush" Value="#D0D0D0"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4,0"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <ribbon:SfRibbon Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">

            <ribbon:SfRibbon.Tabs>

                <ribbon:RibbonTab Header="Home" Background="#FAFAFA">
                    <ribbon:RibbonGroup Header="Elements" Background="#FAFAFA">
                        <ribbon:RibbonButton Content="Barcode" Command="{Binding Designer.AddBarcodeCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE72E;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Text" Command="{Binding Designer.AddTextCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8D2;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Shape" Command="{Binding Designer.AddShapeCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7B4;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Line" Command="{Binding Designer.AddLineCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE136;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Image" Command="{Binding Designer.AddImageCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Delete" Command="{Binding Designer.DeleteSelectedCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Arrange">
                        <ribbon:RibbonButton Content="Group" Command="{Binding Designer.GroupSelectedCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7B4;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Ungroup" Command="{Binding Designer.UngroupSelectedCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7B4;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Clipboard">
                        <ribbon:RibbonButton Content="Copy" Command="{Binding Designer.CopySelectedCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8C8;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Paste" Command="{Binding Designer.PasteElementCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE77F;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="View">
                        <StackPanel>
                            <ribbon:RibbonButton Content="Fit" Command="{Binding Designer.ZoomToFitCommand}">
                                <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE950;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                            </ribbon:RibbonButton>
                            <ToggleButton x:Name="LayersToggle" Content="Layers" IsChecked="True"
                                Margin="0,4,0,0" Padding="6,2" FontSize="11"
                                Checked="OnLayersPaneToggled" Unchecked="OnLayersPaneToggled"
                                ToolTipService.ToolTip="Show/hide Layers panel"/>
                            <ToggleButton x:Name="PropertiesToggle" Content="Properties" IsChecked="True"
                                Margin="0,2,0,0" Padding="6,2" FontSize="11"
                                Checked="OnPropertiesPaneToggled" Unchecked="OnPropertiesPaneToggled"
                                ToolTipService.ToolTip="Show/hide Properties panel"/>
                            <Button Content="Reset Layout" Click="OnResetLayout"
                                Margin="0,2,0,0" Padding="6,2" FontSize="11"
                                ToolTipService.ToolTip="Restore default panel layout"/>
                        </StackPanel>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Settings">
                        <StackPanel>
                            <TextBlock Text="Ruler Units" FontSize="11" Margin="0,0,0,4"/>
                            <ComboBox x:Name="RulerUnitComboBox" Width="90" SelectionChanged="OnRulerUnitChanged" SelectedIndex="0">
                                <ComboBoxItem Content="mm" Tag="Millimeters"/>
                                <ComboBoxItem Content="cm" Tag="Centimeters"/>
                                <ComboBoxItem Content="in" Tag="Inches"/>
                            </ComboBox>
                            <ToggleButton x:Name="SnapGridToggle" Content="Grid" IsChecked="True"
                                Margin="0,4,0,0" Padding="6,2" FontSize="11"
                                Checked="OnSnapGridToggled" Unchecked="OnSnapGridToggled"
                                ToolTipService.ToolTip="Show snap grid on canvas"/>
                        </StackPanel>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Page">
                        <ribbon:RibbonButton Content="A4" Command="{Binding Designer.SetPageA4Command}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="A5" Command="{Binding Designer.SetPageA5Command}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="A3" Command="{Binding Designer.SetPageA3Command}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Flip" Command="{Binding Designer.ToggleOrientationCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7AD;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="4x5" Command="{Binding Designer.SetPageLabel4x5Command}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="6x4" Command="{Binding Designer.SetPageLabel6x4Command}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="8x3" Command="{Binding Designer.SetPageLabel8x3Command}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7C3;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Rotate">
                        <ribbon:RibbonButton Content="Rot 90" Command="{Binding Designer.RotateElementCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7AD;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Data">
                        <ribbon:RibbonButton Content="CSV" Command="{Binding Designer.LoadDataSourceCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8E5;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="Print All" Command="{Binding Designer.PrintWithDataCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE749;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Preview">
                        <ribbon:RibbonButton Content="Preview" Command="{Binding Designer.PreviewPrintCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                    <ribbon:RibbonGroup Header="Export">
                        <ribbon:RibbonButton Content="Print" Command="{Binding Designer.PrintCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE749;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="PDF" Command="{Binding Designer.ExportPdfCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE8A5;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                        <ribbon:RibbonButton Content="PNG" Command="{Binding Designer.ExportPngCommand}">
                            <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xEB9F;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                        </ribbon:RibbonButton>
                    </ribbon:RibbonGroup>
                </ribbon:RibbonTab>

            </ribbon:SfRibbon.Tabs>

            <ribbon:SfRibbon.ContextualTabGroups>
                <ribbon:RibbonContextualTabGroup
            Visibility="{Binding Designer.IsBarcodeSelected, Converter={StaticResource BoolToVisibility}}">
                    <ribbon:RibbonContextualTabGroup.Tabs>
                        <ribbon:RibbonTab Header="Barcode">
                            <ribbon:RibbonGroup Header="Text Position">
                                <ribbon:RibbonButton Content="Top" Command="{Binding Designer.SetTextTopCommand}">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74A;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                                <ribbon:RibbonButton Content="Bottom" Command="{Binding Designer.SetTextBottomCommand}">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE74B;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                                <ribbon:RibbonButton Content="Left" Command="{Binding Designer.SetTextLeftCommand}">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE76B;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                                <ribbon:RibbonButton Content="Right" Command="{Binding Designer.SetTextRightCommand}">
                                    <ribbon:RibbonButton.Icon><FontIcon Glyph="&#xE76C;" FontFamily="Segoe MDL2 Assets"/></ribbon:RibbonButton.Icon>
                                </ribbon:RibbonButton>
                            </ribbon:RibbonGroup>
                        </ribbon:RibbonTab>
                    </ribbon:RibbonContextualTabGroup.Tabs>
                </ribbon:RibbonContextualTabGroup>
            </ribbon:SfRibbon.ContextualTabGroups>

        </ribbon:SfRibbon>

        <controls:RulerControl Grid.Row="1" Viewport="{Binding Designer.Viewport}" Background="#F5F5F5"/>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition x:Name="LayerColumn" Width="180"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition x:Name="PropertiesColumn" Width="220"/>
            </Grid.ColumnDefinitions>

            <controls:RulerControl Grid.Column="0" x:Name="LeftRuler" IsVertical="True"
                Viewport="{Binding Designer.Viewport}" Background="#F5F5F5"/>

            <Border Grid.Column="2" x:Name="SplitterLeft" Width="6" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                PointerPressed="OnSplitterPressed" PointerMoved="OnSplitterMoved" PointerReleased="OnSplitterReleased"/>

            <views:LayersPaneView Grid.Column="1" x:Name="LayersPane"/>

            <views:DesignerCanvasView Grid.Column="3"/>

            <Border Grid.Column="4" x:Name="SplitterRight" Width="6" Background="#F0F2F5" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                PointerPressed="OnSplitterPressed" PointerMoved="OnSplitterMoved" PointerReleased="OnSplitterReleased"/>

            <views:PropertiesPaneView Grid.Column="5" x:Name="PropertiesPane"/>
        </Grid>

        <Border Grid.Row="3" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" Padding="4,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Designer.RulerUnitText}" Margin="6,0,2,0" VerticalAlignment="Center" FontSize="12" Foreground="#555"/>
                <TextBlock Grid.Column="1" Text="|" VerticalAlignment="Center" FontSize="12" Foreground="#CCC"/>
                <TextBlock Grid.Column="2" FontSize="12" VerticalAlignment="Center" Foreground="#555" Margin="4,0" Text="{Binding Designer.ZoomText}"/>
                <Button Grid.Column="4" Content="-" Margin="1,0" Padding="0" MinWidth="22" Height="20" FontSize="14" Command="{Binding Designer.ZoomOutCommand}"/>
                <Button Grid.Column="5" Content="+" Margin="1,0" Padding="0" MinWidth="22" Height="20" FontSize="14" Command="{Binding Designer.ZoomInCommand}"/>
                <Button Grid.Column="6" Content="Fit" Margin="1,0" Padding="4,0" Height="20" FontSize="11" Command="{Binding Designer.ZoomToFitCommand}"/>
                <TextBlock Grid.Column="7" FontSize="12" VerticalAlignment="Center" Foreground="#555" Margin="8,0,0,0" Text="{Binding Designer.CursorText}"/>
                <TextBlock Grid.Column="8" FontSize="12" VerticalAlignment="Center" Foreground="#555" Margin="12,0,6,0" Text="{Binding Designer.ElementsText}"/>
            </Grid>
        </Border>

    </Grid>
</Window>
