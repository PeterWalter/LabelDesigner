<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="LabelDesigner.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LabelDesigner.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="#ECEEF2"/>
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#F2F4F7"/>
                    <SolidColorBrush x:Key="AppSurfaceSubtleBrush" Color="#F7F8FA"/>
                    <SolidColorBrush x:Key="AppPaneItemBrush" Color="#E8EDF3"/>
                    <SolidColorBrush x:Key="AppPaneBadgeBrush" Color="#D0DCE8"/>
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#DDE1E7"/>
                    <SolidColorBrush x:Key="AppTextBrush" Color="#111827"/>
                    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#4B5563"/>
                    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#6B7280"/>
                    <SolidColorBrush x:Key="AppStatusTextBrush" Color="#374151"/>
                    <SolidColorBrush x:Key="AppStatusSeparatorBrush" Color="#D1D5DB"/>
                    <SolidColorBrush x:Key="AppGlyphBrush" Color="#374151"/>
                    <SolidColorBrush x:Key="AppSecondaryGlyphBrush" Color="#6B7280"/>
                    <SolidColorBrush x:Key="AppBadgeTextBrush" Color="#1E3A5F"/>
                    <SolidColorBrush x:Key="AppSelectedTextBrush" Color="#FFFFFF"/>
                    <!-- Active layer -->
                    <SolidColorBrush x:Key="AppActiveLayerBgBrush" Color="#EBF3FE"/>
                    <SolidColorBrush x:Key="AppActiveLayerAccentBrush" Color="#0078D4"/>
                    <SolidColorBrush x:Key="AppActivePillBgBrush" Color="#0078D4"/>
                    <SolidColorBrush x:Key="AppActivePillTextBrush" Color="#FFFFFF"/>
                    <SolidColorBrush x:Key="AppLockedPillBgBrush" Color="#FFF3E0"/>
                    <SolidColorBrush x:Key="AppLockedPillTextBrush" Color="#B45309"/>
                    <SolidColorBrush x:Key="AppLayerRowHoverBrush" Color="#F0F5FF"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppShellBackgroundBrush" Color="#1A1B1E"/>
                    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#242528"/>
                    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#2C2D31"/>
                    <SolidColorBrush x:Key="AppSurfaceSubtleBrush" Color="#313235"/>
                    <SolidColorBrush x:Key="AppPaneItemBrush" Color="#2E3038"/>
                    <SolidColorBrush x:Key="AppPaneBadgeBrush" Color="#3D4350"/>
                    <SolidColorBrush x:Key="AppBorderBrush" Color="#3B3D44"/>
                    <SolidColorBrush x:Key="AppTextBrush" Color="#F1F3F5"/>
                    <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#CDD0D6"/>
                    <SolidColorBrush x:Key="AppMutedTextBrush" Color="#9CA3AF"/>
                    <SolidColorBrush x:Key="AppStatusTextBrush" Color="#D1D5DB"/>
                    <SolidColorBrush x:Key="AppStatusSeparatorBrush" Color="#4B5563"/>
                    <SolidColorBrush x:Key="AppGlyphBrush" Color="#D1D5DB"/>
                    <SolidColorBrush x:Key="AppSecondaryGlyphBrush" Color="#B8C2D0"/>
                    <SolidColorBrush x:Key="AppBadgeTextBrush" Color="#E0E8F5"/>
                    <SolidColorBrush x:Key="AppSelectedTextBrush" Color="#FFFFFF"/>
                    <!-- Active layer -->
                    <SolidColorBrush x:Key="AppActiveLayerBgBrush" Color="#142033"/>
                    <SolidColorBrush x:Key="AppActiveLayerAccentBrush" Color="#60CDFF"/>
                    <SolidColorBrush x:Key="AppActivePillBgBrush" Color="#003F6C"/>
                    <SolidColorBrush x:Key="AppActivePillTextBrush" Color="#60CDFF"/>
                    <SolidColorBrush x:Key="AppLockedPillBgBrush" Color="#3D2500"/>
                    <SolidColorBrush x:Key="AppLockedPillTextBrush" Color="#FFB900"/>
                    <SolidColorBrush x:Key="AppLayerRowHoverBrush" Color="#252A35"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
